; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="SettingOff"
run/main_scene="uid://bd5u2ua7n4f8b"
config/features=PackedStringArray("4.6", "Forward Plus")
run/max_fps=60
boot_splash/image="uid://dkn7pf25bihty"
config/icon="res://icon.svg"
boot_splash/minimum_display_time=500

[audio]

buses/default_bus_layout="uid://c5sabb7ujb8x8"

[autoload]

global_vars="*uid://fwyqcnfpdlq8"
DialogueManager="*uid://c3rodes2l3gxb"
States="*uid://fshnrilv8ca8"

[dialogue_manager]

runtime/balloon_path="res://dialogue/balloon.tscn"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=3
window/stretch/mode="canvas_items"

[editor]

export/convert_text_resources_to_binary=false

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogue_manager/plugin.cfg")

